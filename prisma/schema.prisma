generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  HR
  PM
  DEV
  USER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)
  accounts      Account[]
  sessions      Session[]
  projects      Project[]
  workspaces    Workspace[]
  pages         Page[]
  assignedTasks Task[]          @relation("AssignedTasks")
  reportedTasks Task[]          @relation("ReportedTasks")
  profile       EmployeeProfile?
  attendanceLogs AttendanceLog[]
  leaveRequests  LeaveRequest[]  @relation("UserLeaves")
  approvedLeaves LeaveRequest[]  @relation("ApprovedLeaves")
  notifications  Notification[]
  taskComments   TaskComment[]
  managerId      String?
  manager        User?           @relation("UserManager", fields: [managerId], references: [id])
  subordinates   User[]          @relation("UserManager")
  attendanceRequests     AttendanceRequest[] @relation("UserAttendanceRequests")
  approvedAttendanceReqs AttendanceRequest[] @relation("ApprovedAttendanceRequests")
  leaveBalances         LeaveBalance[]
}

model LeaveBalance {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // e.g., CASUAL, SICK, EARNED
  total       Float    @default(0)
  used        Float    @default(0)
  available   Float    @default(0)
  year        Int      @default(2026)
  updatedAt   DateTime @updatedAt

  @@unique([userId, type, year])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}


model Team {
  id      String       @id @default(cuid())
  name    String
  pmId    String?
  members TeamMember[]
  shifts  Shift[]
  rotas   RotaGeneration[]
  projects Project[]
}

model TeamMember {
  id           String  @id @default(cuid())
  name         String
  email        String
  teamId       String?
  team         Team?   @relation(fields: [teamId], references: [id])
  fixedShiftId String?
  lastShiftId  String?
  leaves       Leave[]
}

model Shift {
  id        String   @id @default(cuid())
  name      String
  startTime String
  endTime   String
  color     String
  sequence  Int
  isExtreme Boolean
  minTeam   Int
  maxTeam   Int
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model Leave {
  id        String     @id @default(cuid())
  memberId  String
  member    TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  startDate String
  endDate   String
  type      String
}

model RotaGeneration {
  id                      String            @id @default(cuid())
  startDate               String
  endDate                 String
  teamId                  String
  team                    Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  assignments             Json
  teamMembersAtGeneration Json?
  manualOverrides         Json?
  manualSwaps             Json?
  manualWeekendSwaps      Json?
  comments                Json?
  adhoc                   Json?
  weekendRotas            WeekendRota[]
}

model WeekendRota {
  id           String         @id @default(cuid())
  date         String
  memberId     String
  generationId String
  generation   RotaGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)
}

model AttendanceLog {
  id             String   @id @default(cuid())
  userId         String
  loginTime      DateTime @default(now())
  logoutTime     DateTime?
  loginLocation  String?
  logoutLocation String?
  latitude       Float?
  longitude      Float?
  accuracy       Float?
  status         String   @default("LOGGED_IN") // LOGGED_IN, LOGGED_OUT, AUTO_LOGOUT
  isWfh          Boolean  @default(false)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AttendanceRequest {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("UserAttendanceRequests", fields: [userId], references: [id])
  type        String   // CLOCK_IN, CLOCK_OUT, FULL_DAY
  date        DateTime
  reason      String
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  approverId  String?
  approver    User?    @relation("ApprovedAttendanceRequests", fields: [approverId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AttendanceSettings {
  id                String  @id @default(cuid())
  geofencingEnabled Boolean @default(true)
  officeLat         Float   @default(19.0760) // Default Mumbai
  officeLng         Float   @default(72.8777)
  allowedRadius     Int     @default(500)     // meters
  wfhAllowed        Boolean @default(true)
  updatedAt         DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  name        String
  key         String   @unique
  description String?
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])
  teamId      String?
  team        Team?    @relation(fields: [teamId], references: [id])
  tasks       Task[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskType {
  BUG
  TASK
  STORY
  EPIC
}

model Task {
  id          String        @id @default(cuid())
  key         String        @unique
  title       String
  description String?
  status      TaskStatus    @default(TODO)
  priority    TaskPriority  @default(MEDIUM)
  type        TaskType      @default(TASK)
  reporterId  String
  reporter    User          @relation("ReportedTasks", fields: [reporterId], references: [id])
  assigneeId  String?
  assignee    User?         @relation("AssignedTasks", fields: [assigneeId], references: [id])
  projectId   String
  project        Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskComments   TaskComment[]
  createdAt      DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model TaskComment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Workspace {
  id          String   @id @default(cuid())
  name        String
  description String?
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])
  pages       Page[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Page {
  id          String    @id @default(cuid())
  title       String
  content     String?   @db.Text
  parentId    String?
  parent      Page?     @relation("PageHierarchy", fields: [parentId], references: [id])
  children    Page[]    @relation("PageHierarchy")
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model EmployeeProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeId      String   @unique
  department      String?
  designation     String?
  phoneNumber     String?
  emergencyContact String?
  dateOfJoining   DateTime @default(now())
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model LeaveRequest {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation("UserLeaves", fields: [userId], references: [id])
  type        String      // e.g., CASUAL, SICK, EARNED
  startDate   DateTime
  endDate     DateTime
  isHalfDay   Boolean     @default(false)
  duration    Float       @default(1.0)
  status      LeaveStatus @default(PENDING)
  reason      String?
  isPaid      Boolean     @default(true)
  approverId  String?
  approver    User?       @relation("ApprovedLeaves", fields: [approverId], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String
  type        String   @default("info") // success, alert, task, info
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
}
